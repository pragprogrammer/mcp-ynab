---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const links = [
  { href: '/', label: 'Home' },
  { href: '/setup', label: 'Setup' },
  { href: '/docs', label: 'Docs' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="fixed top-0 w-full z-50 border-b border-white/5 bg-[#0a0a0a]/80 backdrop-blur-xl">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-lg font-semibold tracking-tight">
      <span class="text-cyan-400">YNAB</span> <span class="text-gray-400 font-normal">MCP</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'hover:text-gray-100 transition-colors hidden sm:block',
            isActive(link.href) ? 'text-gray-100' : '',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href="https://github.com/pragprogrammer/mcp-ynab" target="_blank" rel="noopener" class="hover:text-gray-100 transition-colors flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </div>
</nav>
